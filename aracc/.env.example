# ar-acc — variables de entorno (copiar a .env)

# ── Neo4j ──────────────────────────────────────────────────
# Cambiá esta contraseña antes de cualquier despliegue real.
NEO4J_PASSWORD=aracc-dev-pass
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j

# Memoria de Neo4j (dev). Para el grafo nacional completo subir a
# HEAP_MAX=8G / PAGECACHE=12G en un servidor con 32GB+ de RAM.
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512m

# ── ETL ────────────────────────────────────────────────────
# Directorio de datos crudos/derivados (montado en el contenedor etl).
DATA_DIR=./data
LOG_LEVEL=info
